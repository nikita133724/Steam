+++ b/src/launcher.py
@@ -0,0 +1,65 @@
+from __future__ import annotations
+
+from pathlib import Path
+import os
+import shutil
+import subprocess
+import sys
+
+from src.paths import get_data_dir, get_install_dir, get_installed_exe
+from src.update_manager import UpdateManager
+
+
+def _is_frozen() -> bool:
+    return bool(getattr(sys, "frozen", False))
+
+
+def _restart(exe: Path) -> None:
+    subprocess.Popen([str(exe)], cwd=str(exe.parent))
+
+
+def _apply_staged_update(exe_path: Path) -> None:
+    staged = exe_path.with_suffix(exe_path.suffix + ".new")
+    if not staged.exists() or not exe_path.exists():
+        return
+
+    backup = exe_path.with_suffix(exe_path.suffix + ".bak")
+    try:
+        if backup.exists():
+            backup.unlink()
+        exe_path.replace(backup)
+        staged.replace(exe_path)
+        backup.unlink(missing_ok=True)
+    except Exception:
+        if backup.exists() and not exe_path.exists():
+            backup.replace(exe_path)
+
+
+def bootstrap_startup() -> int | None:
+    install_dir = get_install_dir()
+    data_dir = get_data_dir()
+    install_dir.mkdir(parents=True, exist_ok=True)
+    data_dir.mkdir(parents=True, exist_ok=True)
+
+    if sys.platform != "win32" or not _is_frozen():
+        return None
+
+    current_exe = Path(sys.executable).resolve()
+    installed_exe = get_installed_exe().resolve()
+
+    if current_exe != installed_exe:
+        shutil.copy2(current_exe, installed_exe)
+        _restart(installed_exe)
+        return 0
+
+    _apply_staged_update(installed_exe)
+
+    manager = UpdateManager(current_exe=installed_exe)
+    try:
+        manifest = manager.fetch_manifest(timeout=8)
+        manager.stage_update(manifest, timeout=30)
+    except Exception:
+        # Сетевые/релизные проблемы не должны блокировать запуск UI.
+        pass
+
+    return None
